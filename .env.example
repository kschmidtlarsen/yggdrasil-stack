# ═══════════════════════════════════════════════════════════════════════════════
# YGGDRASIL - Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to Portainer Stack Environment Variables

# ─────────────────────────────────────────────────────────────────────────────
# URD (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=urd
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─────────────────────────────────────────────────────────────────────────────
# PGADMIN
# ─────────────────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@exe.pm
PGADMIN_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────────────────────────────────────
# MIMIR
# ─────────────────────────────────────────────────────────────────────────────
CLAUDE_CODE_OAUTH_TOKEN=
MIMIR_ENCRYPTION_SECRET=
MIMIR_INTERNAL_API_TOKEN=
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# SHARED SECRETS
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_STRING
WEBSOCKET_KEY=CHANGE_ME_GENERATE_RANDOM_STRING

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL APIS
# ─────────────────────────────────────────────────────────────────────────────
# Stripe (Calify, Sorring3D, Night Tales)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (Night Tales, Sorring Udlejning, WODForge)
OPENAI_API_KEY=sk-...

# Resend (Email for multiple apps)
RESEND_API_KEY=re_...
